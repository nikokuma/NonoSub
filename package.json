{
  "name": "nonosub",
  "version": "0.1.0",
  "description": "Interactive subtitles that turn foreign-language media into a language lesson.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:rust": "cargo test --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "audit:nono-rig": "node scripts/audit_nono_glb.mjs",
    "verify": "pnpm check && pnpm test && pnpm build && pnpm check:rust",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/dotgothic16": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/klee-one": "^5.2.8",
    "@fontsource/share-tech-mono": "^5.2.7",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/cli": "^2",
    "@types/three": "^0.185.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
